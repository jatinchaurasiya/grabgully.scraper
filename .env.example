# ═══════════════════════════════════════════════════════════════════════════════
#  GRAB GULLY SCRAPER — Environment Variables
#  Copy this file to .env and fill in all values before running locally.
#  On Railway: add each of these under Settings > Variables.
#  NEVER commit .env to Git. It is in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────────────────────────────
APP_ENV=production                          # production | development
APP_VERSION=2.0.0
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SCRAPER_SECRET=CHANGE_ME_32_CHAR_HEX_SECRET
ALLOWED_ORIGINS=https://grabgully.com,https://admin.grabgully.com

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# From: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...YOUR_SERVICE_ROLE_KEY  # NEVER the anon key

# ─── REDIS (Upstash) ──────────────────────────────────────────────────────────
# From: console.upstash.com > Your Redis DB > REST API section
UPSTASH_REDIS_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_TOKEN=AXxxxxxxx...

# ─── AMAZON CREATOR API ───────────────────────────────────────────────────────
# NOTE: We use Amazon Creator API (Content Creator Program), NOT PA-API 5.0.
# The Creator API uses OAuth2 LWA (Login with Amazon) — no AWS Signature V4.
#
# Step 1: Join Amazon Creator Program → https://affiliate.amazon.in
# Step 2: Go to Tools > Creator API (Content Creator)
# Step 3: Create an "LWA Security Profile" → get Client ID + Secret
#
AMAZON_CLIENT_ID=amzn1.application-oa2-client.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AMAZON_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AMAZON_PARTNER_TAG=grabgully-21            # Your Associates tracking ID (stays the same)

# ─── CUELINK AFFILIATE API ────────────────────────────────────────────────────
# Used for ALL platform affiliate links: Flipkart, Myntra, Meesho, Ajio, Snapdeal.
# CueLink auto-detects the merchant from the URL and applies your registered tracking.
#
# Step 1: Register at https://cuelinks.com
# Step 2: Join merchant programs (Flipkart, Myntra, etc.) inside CueLink dashboard
# Step 3: Go to API section → Generate API Key
#
CUELINK_API_KEY=YOUR_CUELINK_BEARER_TOKEN

# ─── FIREBASE (FCM for push notifications) ────────────────────────────────────
# From: Firebase Console > Project Settings > Service Accounts > Generate Key
FIREBASE_PROJECT_ID=grab-gully-android
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── SCRAPER BEHAVIOUR ────────────────────────────────────────────────────────
SCRAPE_INTERVAL_MINUTES=30                  # How often to run scrapers
SCRAPE_START_HOUR=6                         # IST hour to start scraping (saves Railway credits)
SCRAPE_END_HOUR=23                          # IST hour to stop scraping
REQUEST_DELAY_SECONDS=4                     # Polite delay between platform requests
MAX_PRODUCTS_PER_CATEGORY=50               # Cap per scrape run
PRICE_DROP_CHECK_INTERVAL_MINUTES=15        # How often to check for price drops
